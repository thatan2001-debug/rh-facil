# ═══════════════════════════════════════════════════════════════════════════
# Gestor RH IA — Ejemplo de variables de entorno
# ═══════════════════════════════════════════════════════════════════════════
#
# INSTRUCCIONES:
#   1. Copia este archivo a `.env` (comando: cp .env.example .env)
#   2. Rellena los valores reales
#   3. NUNCA subas el archivo `.env` a Git — ya está en .gitignore
#   4. En producción (Render), estas variables se configuran en el Dashboard
#      del servicio → Environment
#
# ═══════════════════════════════════════════════════════════════════════════

# ── ENTORNO ────────────────────────────────────────────────────────────────
# Valores: development | production
# En development: se permite fallback JSON local si no hay Supabase
# En production: la app NO arranca si no hay Supabase configurado
ENVIRONMENT=development

# URL pública de la aplicación (para enlaces en correos)
APP_URL=http://localhost:8501

# ── SUPABASE ───────────────────────────────────────────────────────────────
# Obtén estos valores en: https://supabase.com/dashboard → tu proyecto → Settings → API
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_KEY=tu_service_role_key_aqui

# ── CORREO SMTP (Brevo recomendado) ────────────────────────────────────────
# Regístrate gratis en https://www.brevo.com — 300 correos/día
# En Brevo: SMTP & API → SMTP → generar clave
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=tu_login_smtp_de_brevo
SMTP_PASS=tu_clave_smtp_de_brevo
SMTP_FROM=Gestor RH IA <noreply@tudominio.com>

# ── SEGURIDAD ──────────────────────────────────────────────────────────────
# Argon2 — parámetros (valores por defecto son seguros para 2026)
# Ajusta solo si sabes lo que haces
ARGON2_TIME_COST=3
ARGON2_MEMORY_COST=65536
ARGON2_PARALLELISM=4

# Rate limiting en login
LOGIN_MAX_INTENTOS=5
LOGIN_VENTANA_MINUTOS=15
LOGIN_BLOQUEO_MINUTOS=15

# ── COMERCIAL ──────────────────────────────────────────────────────────────
# WhatsApp para atención comercial (número Colombia con código país)
WHATSAPP_NUMERO=573001234567

# ═══════════════════════════════════════════════════════════════════════════
# NOTAS DE SEGURIDAD:
# - Ninguna de estas variables debe compartirse en imágenes, chat o docs
# - Si alguna clave se filtra, rótala en el proveedor correspondiente
# - Ver SECURITY.md para más detalles
# ═══════════════════════════════════════════════════════════════════════════
